<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:InstructorPlus.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="InstructorPlus.Views.StudentEditWindow"
        x:DataType="vm:StudentEditViewModel"
        Title="Редактирование ученика"
        WindowState="Maximized">

        <ScrollViewer >
        <Grid RowDefinitions="Auto Auto" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.Styles>
                        <Style Selector="Grid > Button">
                                <Setter Property="FontSize" Value="28"/>
                                <Setter Property="FontWeight" Value="Black"/>
                                <Setter Property="Width" Value="170"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,10,0,0"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#2a4252"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                </Grid.Styles>
                        <StackPanel >
                                <StackPanel.Styles>
                                        <Style Selector="StackPanel > TextBlock">
                                                <Setter Property="FontSize" Value="28"/>
                                                <Setter Property="Width" Value="440"/>
                                                <Setter Property="Foreground" Value="#2a4252"/>
                                                <Setter Property="FontWeight" Value="Black"/>
                                        </Style>
                                        <Style Selector="StackPanel > TextBox">
                                                <Setter Property="FontSize" Value="28"/>
                                                <Setter Property="Margin" Value="0 2 0 10"/>
                                                <Setter Property="Width" Value="440"/>
                                                <Setter Property="Foreground" Value="#2a4252"/>
                                        </Style>
                                        <Style Selector="StackPanel > DatePicker">
                                                <Setter Property="FontSize" Value="24"/>
                                                <Setter Property="Margin" Value="0 2 0 10"/>
                                                <Setter Property="Width" Value="440"/>
                                                <Setter Property="Foreground" Value="#2a4252"/>
                                        </Style>
                                        <Style Selector="StackPanel > TimePicker">
                                                <Setter Property="FontSize" Value="24"/>
                                                <Setter Property="Margin" Value="0 2 0 10"/>
                                                <Setter Property="Width" Value="440"/>
                                                <Setter Property="Foreground" Value="#2a4252"/>
                                        </Style>
                                        <Style Selector="StackPanel > ComboBox">
                                                <Setter Property="FontSize" Value="28"/>
                                                <Setter Property="Margin" Value="0 2 0 10"/>
                                                <Setter Property="Width" Value="440"/>
                                                <Setter Property="Foreground" Value="#2a4252"/>
                                        </Style>
                                </StackPanel.Styles>
                                
                                <TextBlock Text="Имя" >
                                        <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                                <TextBox Text="{Binding SelectedName}"/>

                                <TextBlock Text="Телефон" >
                                        <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                                <TextBox Text="{Binding SelectedPhone}"/>
                                
                                <TextBlock Text="Филиал" >
                                        <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                                <ComboBox ItemsSource="{Binding Branches}" DisplayMemberBinding="{Binding Name}" SelectedItem="{Binding SelectedBranch}"/>

                                <TextBlock Text="Часов оплачено"/>
                                <TextBox Text="{Binding SelectedTotalHoursRequired}"/>
                                
                                <TextBlock Text="Дата поступления" >
                                        <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                                <DatePicker SelectedDate="{Binding SelectedDate}" />
                        </StackPanel>
                <Button Grid.Row="1" HorizontalAlignment="Left" Content="Отмена" Command="{Binding CancelCommand}"/>
                <Button Grid.Row="1" HorizontalAlignment="Right" Content="Сохранить" Command="{Binding SaveCommand}"/>
        </Grid>
        </ScrollViewer>
</Window>
